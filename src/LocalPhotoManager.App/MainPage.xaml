<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="LocalPhotoManager.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:LocalPhotoManager.App"
    xmlns:viewModels="using:LocalPhotoManager.App.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="124" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="{x:Bind ViewModel.InformationPaneWidth, Mode=OneWay}" />
        </Grid.ColumnDefinitions>

        <Border Grid.ColumnSpan="3" Padding="12,6" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <MenuBar VerticalAlignment="Center">
                    <MenuBarItem Title="文件">
                        <MenuFlyoutItem Text="扫描文件夹" Command="{x:Bind ViewModel.ScanFolderCommand}" />
                    </MenuBarItem>
                    <MenuBarItem Title="编辑">
                        <MenuFlyoutItem Text="收藏" />
                    </MenuBarItem>
                    <MenuBarItem Title="视图">
                        <MenuFlyoutItem Text="全部照片" Click="OnPhotosClick" />
                        <MenuFlyoutItem Text="文件夹" Click="OnFoldersClick" />
                        <MenuFlyoutItem Text="时间线" Click="OnTimelineClick" />
                    </MenuBarItem>
                    <MenuBarItem Title="帮助">
                        <MenuFlyoutItem Text="关于 Local Photo Manager" />
                    </MenuBarItem>
                </MenuBar>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{x:Bind ViewModel.ViewTitle, Mode=OneWay}" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" Opacity="0.7" TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                    <ProgressRing Width="22" Height="22" IsActive="{x:Bind ViewModel.IsScanning, Mode=OneWay}" />
                    <Button Content="扫描文件夹" Command="{x:Bind ViewModel.ScanFolderCommand}" />
                    <Button Content="取消" Command="{x:Bind ViewModel.CancelScanCommand}" />
                    <Button Command="{x:Bind ViewModel.ToggleInformationPaneCommand}" ToolTipService.ToolTip="显示或隐藏照片信息">
                        <FontIcon Glyph="&#xE946;" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <InfoBar Grid.Row="1" Grid.ColumnSpan="3" Margin="12,8,12,8" IsOpen="True" IsClosable="False" Severity="Informational"
                 Title="隐私优先" Message="图片只会在本机索引；扫描不会修改、移动或上传原始文件。" />

        <ScrollViewer Grid.Row="2" Grid.RowSpan="2" Grid.Column="0" Padding="12,0,12,12">
            <StackPanel Spacing="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="功能" Opacity="0.65" />
                    <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="OnPhotosClick">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xEB9F;" />
                            <TextBlock Text="全部照片" />
                        </StackPanel>
                    </Button>
                    <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="OnFoldersClick">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8B7;" />
                            <TextBlock Text="文件夹" />
                        </StackPanel>
                    </Button>
                    <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="OnTimelineClick">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE787;" />
                            <TextBlock Text="时间线" />
                        </StackPanel>
                    </Button>
                    <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="OnFavoritesClick">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE734;" />
                            <TextBlock Text="收藏" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="文件夹和子文件夹" Opacity="0.65" />
                    <ListView ItemsSource="{x:Bind ViewModel.Folders, Mode=OneWay}"
                              SelectionMode="Single" IsItemClickEnabled="True" ItemClick="OnFolderItemClick">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:FolderSummaryItem">
                                <Grid Padding="4" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{x:Bind Path}" Opacity="0.62" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{x:Bind CountLabel}" Opacity="0.65" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="时间线" Opacity="0.65" />
                    <ListView ItemsSource="{x:Bind ViewModel.TimelineGroups, Mode=OneWay}"
                              SelectionMode="Single" IsItemClickEnabled="True" ItemClick="OnTimelineItemClick">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:TimelineGroupItem">
                                <Grid Padding="4" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind Title}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind CountLabel}" Opacity="0.65" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Grid.Column="1" Padding="12,0,12,12">
            <Border CornerRadius="6" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                <Grid>
                    <FontIcon Glyph="&#xEB9F;" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="64" Opacity="0.35" />
                    <Image Source="{x:Bind ViewModel.SelectedPreviewImage, Mode=OneWay}" Stretch="Uniform" />
                </Grid>
            </Border>
        </Grid>

        <ScrollViewer Grid.Row="2" Grid.Column="2" Padding="0,0,12,12"
                      Visibility="{x:Bind ViewModel.InformationPaneVisibility, Mode=OneWay}">
            <StackPanel Spacing="12">
                <TextBlock Text="信息" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="{x:Bind ViewModel.SelectedFileName, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap" />
                <TextBlock Text="{x:Bind ViewModel.SelectedFolder, Mode=OneWay}" Opacity="0.75" TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{x:Bind ViewModel.SelectedDetails, Mode=OneWay}" Opacity="0.75" TextWrapping="Wrap" />
                <TextBlock Text="{x:Bind ViewModel.SelectedDate, Mode=OneWay}" Opacity="0.75" TextWrapping="Wrap" />
                <TextBlock Text="{x:Bind ViewModel.SelectedCamera, Mode=OneWay}" Opacity="0.75" TextWrapping="Wrap" />
                <TextBlock Text="{x:Bind ViewModel.SelectedPath, Mode=OneWay}" Opacity="0.65" TextWrapping="WrapWholeWords" />
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Padding="12,0,12,12" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Width="44" Height="72" VerticalAlignment="Center" Command="{x:Bind ViewModel.SelectPreviousPhotoCommand}" ToolTipService.ToolTip="上一张">
                <FontIcon Glyph="&#xE76B;" />
            </Button>

            <ListView Grid.Column="1" ItemsSource="{x:Bind ViewModel.Photos, Mode=OneWay}"
                      SelectionMode="Single" IsItemClickEnabled="True" ItemClick="OnPhotoItemClick">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsStackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:PhotoListItem">
                        <Grid Width="96" Padding="4" RowSpacing="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="72" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border CornerRadius="4" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                <Grid>
                                    <FontIcon Glyph="&#xEB9F;" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.45" />
                                    <Image Source="{x:Bind Thumbnail, Mode=OneWay}" Stretch="UniformToFill" />
                                </Grid>
                            </Border>
                            <TextBlock Grid.Row="1" Text="{x:Bind FileName}" TextTrimming="CharacterEllipsis" Opacity="0.75" FontSize="11" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Button Grid.Column="2" Width="44" Height="72" VerticalAlignment="Center" Command="{x:Bind ViewModel.SelectNextPhotoCommand}" ToolTipService.ToolTip="下一张">
                <FontIcon Glyph="&#xE76C;" />
            </Button>
        </Grid>
    </Grid>
</Page>
